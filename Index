                    <button onclick="updateRequestStatus('${type}', ${item.id}, 'Ditolak')" class="text-red-500 hover:text-red-700 bg-red-50 p-1.5 rounded-lg transition-transform active:scale-90" title="Tolak"><i class="fas fa-times"></i></button>
                ` : `<span class="text-xs text-gray-400 font-medium"><i class="fas fa-flag-checkered mr-1"></i>Selesai</span>`;

                const tr = document.createElement('tr');
                tr.className = "hover:bg-gray-50 transition-colors";
                tr.innerHTML = `
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-3">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-blue-100 to-indigo-100 text-blue-700 flex items-center justify-center font-bold text-xs shadow-sm">KD</div>
                            <div>
                                <p class="text-sm font-bold text-gray-800">${item.name}</p>
                                <p class="text-[10px] text-gray-500">${item.timestamp}</p>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-sm text-gray-800 font-medium">${item.detail1}</td>
                    <td class="py-4 px-6 text-sm text-gray-600">${item.detail2}</td>
                    <td class="py-4 px-6 text-sm text-gray-600 max-w-[200px] truncate" title="${item.detail3}">${item.detail3}</td>
                    <td class="py-4 px-6">${statusBadge}</td>
                    <td class="py-4 px-6 whitespace-nowrap">${actionBtns}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function updateRequestStatus(type, id, newStatus) {
            const req = appState.requests[type].find(r => r.id === id);
            if(req) {
                req.status = newStatus;
                dbUpdate('requests', id, { status: newStatus }); // Update di Supabase
                renderAdminTable(type);
                showToast(`Pengajuan berhasil ${newStatus.toLowerCase()}`, newStatus === 'Disetujui' ? 'success' : 'error');
            }
        }

        function refreshDashboard() {
            const btn = document.getElementById('btn-refresh-dash');
            const icon = document.getElementById('icon-refresh-dash');
            const text = btn.querySelector('span');
            
            icon.classList.add('fa-spin');
            text.innerText = "Memuat...";
            btn.classList.add('opacity-70', 'pointer-events-none');
            
            const tbody = document.getElementById('admin-table-body');
            tbody.innerHTML = `
                <tr>
                    <td colspan="5" class="py-16 text-center">
                        <i class="fas fa-circle-notch fa-spin text-3xl text-blue-500 mb-3"></i>
                        <p class="text-gray-500 text-sm font-medium">Menyinkronkan data terbaru...</p>
                    </td>
                </tr>
            `;
            
            // Reload data dari database (Supabase) jika ada, atau tunggu sejenak jika lokal
            setTimeout(async () => {
                if(supabaseClient) await loadAllData();
                
                icon.classList.remove('fa-spin');
                text.innerText = "Segarkan Data";
                btn.classList.remove('opacity-70', 'pointer-events-none');
                
                renderAdminDashboard();
                showToast('Data kehadiran berhasil disinkronisasi', 'success');
            }, 1200);
        }

        function renderAdminDashboard() {
            const tbody = document.getElementById('admin-table-body');
            tbody.innerHTML = '';

            let hadirCount = 0;
            let telatCount = 0;

            if(appState.history.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="5" class="text-center py-16">
                            <div class="flex flex-col items-center justify-center text-gray-400">
                                <i class="fas fa-inbox text-5xl mb-4 text-gray-300"></i>
                                <p class="text-sm font-medium text-gray-600">Belum ada aktivitas kehadiran hari ini</p>
                                <p class="text-xs mt-1 text-gray-400">Data absensi akan otomatis muncul di sini</p>
                            </div>
                        </td>
                    </tr>
                `;
                document.getElementById('stat-hadir').innerText = 0;
                document.getElementById('stat-telat').innerText = 0;
                return;
            }

            appState.history.forEach(item => {
                if(item.status.includes('Hadir') || item.status.includes('Belum')) hadirCount++;
                if(item.late) telatCount++;

                const photoInHtml = item.photoIn 
                    ? `<img src="${item.photoIn}" class="w-10 h-10 rounded-lg object-cover border border-gray-200 shadow-sm cursor-pointer hover:scale-150 origin-left transition-transform relative z-10">` 
                    : `<div class="w-10 h-10 rounded-lg bg-gray-100 border border-gray-200 flex items-center justify-center text-gray-400 text-xs"><i class="fas fa-camera-slash"></i></div>`;
                
                const photoOutHtml = item.photoOut 
                    ? `<img src="${item.photoOut}" class="w-10 h-10 rounded-lg object-cover border border-gray-200 shadow-sm cursor-pointer hover:scale-150 origin-left transition-transform relative z-10">` 
                    : `<div class="w-10 h-10 rounded-lg bg-gray-100 border border-gray-200 flex items-center justify-center text-gray-400 text-xs"><i class="fas fa-camera-slash"></i></div>`;

                let statusBadge = item.late ? `<span class="px-3 py-1 bg-red-50 text-red-600 rounded-full text-xs font-bold border border-red-100">Terlambat</span>` : `<span class="px-3 py-1 bg-green-50 text-green-600 rounded-full text-xs font-bold border border-green-100">Tepat Waktu</span>`;
                if(item.status.includes('Belum')) statusBadge = `<span class="px-3 py-1 bg-yellow-50 text-yellow-700 rounded-full text-xs font-bold border border-yellow-100">Sedang Bekerja</span>`;

                const tr = document.createElement('tr');
                tr.className = "hover:bg-blue-50/50 transition-colors group";
                tr.innerHTML = `
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-3">
                            <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-blue-100 to-indigo-100 text-blue-700 flex items-center justify-center font-bold text-xs shadow-sm">${item.name ? item.name.substring(0,2).toUpperCase() : 'KD'}</div>
                            <div>
                                <p class="text-sm font-bold text-gray-800 group-hover:text-blue-600 transition-colors">${item.name || 'Nama Karyawan'}</p>
                                <p class="text-[11px] text-gray-500">${item.role || 'Staff'}</p>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-sm text-gray-600 font-medium">${item.date}</td>
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-3">
                            ${photoInHtml}
                            <span class="text-sm font-bold ${item.late ? 'text-red-600' : 'text-gray-700'}">${item.timeIn}</span>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-3">
                            ${photoOutHtml}
                            <span class="text-sm font-bold text-gray-700">${item.timeOut}</span>
                        </div>
                    </td>
                    <td class="py-4 px-6">${statusBadge}</td>
                `;
                tbody.appendChild(tr);
            });

            // Update widget text dashboard
            document.getElementById('stat-hadir').innerText = hadirCount;
            document.getElementById('stat-telat').innerText = telatCount;
        }

        // --- FUNGSI MANAJEMEN PENGUMUMAN ---
        function submitAnnouncement() {
            const title = document.getElementById('input-announcement-title').value;
            const target = document.getElementById('input-announcement-target').value;
            const message = document.getElementById('input-announcement-message').value;

            if (!title || !message) {
                showToast('Judul dan Isi Pesan wajib diisi!', 'error');
                return;
            }

            const now = new Date();
            const dateStr = now.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });

            const newAnnouncement = {
                id: Date.now(),
                title: title,
                target: target,
                message: message,
                date: dateStr
            };

            // Tambahkan ke data terbaru (di urutan pertama)
            appState.announcements.unshift(newAnnouncement);
            dbInsert('announcements', newAnnouncement); // Insert ke Supabase

            // Kosongkan form
            document.getElementById('input-announcement-title').value = '';
            document.getElementById('input-announcement-message').value = '';

            showToast('Pengumuman berhasil disebarkan!', 'success');

            // Render ulang tampilan Admin & Pengguna
            renderAdminAnnouncements();
            renderEmployeeAnnouncements();
        }

        function deleteAnnouncement(id) {
            appState.announcements = appState.announcements.filter(a => a.id !== id);
            dbDelete('announcements', id); // Delete di Supabase
            showToast('Pengumuman berhasil dihapus', 'success');
            renderAdminAnnouncements();
            renderEmployeeAnnouncements();
        }

        function renderAdminAnnouncements() {
            const list = document.getElementById('admin-announcement-list');
            if (!list) return;

            list.innerHTML = '';
            if (appState.announcements.length === 0) {
                list.innerHTML = '<p class="text-sm text-gray-500 text-center py-6 bg-gray-50 rounded-xl">Belum ada pengumuman terkirim.</p>';
                return;
            }

            appState.announcements.forEach((ann, index) => {
                const isBlue = index % 2 === 0; // Bergantian warna agar menarik
                const bgClass = isBlue ? 'bg-blue-50 border-blue-100' : 'bg-gray-50 border-gray-100';
                const textClassTitle = isBlue ? 'text-blue-900' : 'text-gray-800';
                const textClassMsg = isBlue ? 'text-blue-700' : 'text-gray-600';
                const textClassDate = isBlue ? 'text-blue-500' : 'text-gray-400';

                const html = `
                <div class="p-4 border ${bgClass} rounded-xl relative transition-all hover:shadow-md">
                    <button onclick="if(confirm('Apakah Anda yakin ingin menghapus pengumuman ini?')) deleteAnnouncement(${ann.id})" class="absolute top-3 right-3 text-red-400 hover:text-red-600 focus:outline-none transition-transform hover:scale-110">
                        <i class="fas fa-trash"></i>
                    </button>
                    <div class="flex items-center space-x-2 mb-1">
                        <h4 class="font-bold text-sm ${textClassTitle}">${ann.title}</h4>
                        <span class="text-[9px] bg-white px-1.5 py-0.5 rounded shadow-sm font-semibold text-gray-500">${ann.target}</span>
                    </div>
                    <p class="text-xs ${textClassMsg} leading-relaxed">${ann.message}</p>
                    <p class="text-[10px] ${textClassDate} mt-3 font-medium"><i class="fas fa-clock mr-1"></i> Terkirim: ${ann.date}</p>
                </div>`;
                list.insertAdjacentHTML('beforeend', html);
            });
        }

        function renderEmployeeAnnouncements() {
            const container = document.getElementById('employee-announcement-container');
            if (!container) return;

            container.innerHTML = '';

            if (appState.announcements.length === 0) {
                container.innerHTML = `
                <div class="bg-gradient-to-r from-gray-50 to-gray-100 rounded-2xl p-4 mb-8 border border-gray-200/50 flex items-start space-x-4 shadow-sm">
                    <div class="bg-white p-2.5 rounded-full text-gray-400 shadow-sm">
                        <i class="fas fa-info-circle mt-0.5 text-sm"></i>
                    </div>
                    <div>
                        <h3 class="text-sm font-bold text-gray-700">Pusat Informasi</h3>
                        <p class="text-[11px] text-gray-500 mt-1 leading-relaxed">Belum ada pengumuman terbaru dari perusahaan saat ini.</p>
                    </div>
                </div>`;
                return;
            }

            // Tampilkan hanya 1 pengumuman paling baru di banner Beranda Pengguna
            const latest = appState.announcements[0];

            container.innerHTML = `
            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-4 mb-8 border border-blue-100/50 flex items-start space-x-4 shadow-sm relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-2 opacity-5 transition-transform group-hover:scale-110 group-hover:rotate-12 duration-500"><i class="fas fa-bullhorn text-6xl"></i></div>
                <div class="bg-white p-2.5 rounded-full text-blue-600 shadow-sm relative z-10 shrink-0">
                    <i class="fas fa-bullhorn mt-0.5 text-sm"></i>
                </div>
                <div class="relative z-10 pr-2 w-full">
                    <div class="flex items-center justify-between mb-1">
                        <h3 class="text-sm font-bold text-blue-900">${latest.title}</h3>
                        <span class="text-[9px] bg-blue-100 text-blue-600 px-1.5 py-0.5 rounded font-bold shadow-sm whitespace-nowrap">${latest.date}</span>
                    </div>
                    <p class="text-[11px] text-blue-700 leading-relaxed pr-4">${latest.message}</p>
                </div>
