        function processAbsen(jenis, photoUrl) {
            const now = new Date();
            const timeStr = `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
            const dateStr = now.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
            const isLate = now.getHours() >= 8 && now.getMinutes() > 0;
            
            const btnMasuk = document.getElementById('btn-masuk');
            const btnPulang = document.getElementById('btn-pulang');
            const statusSelesai = document.getElementById('status-selesai');
            const msg = document.getElementById('absen-message');

            if (jenis === 'masuk') {
                appState.hasClockedIn = true;
                appState.timeIn = timeStr;
                document.getElementById('status-time-in').innerText = timeStr;
                btnMasuk.classList.add('hidden');
                btnPulang.classList.remove('hidden');
                msg.innerText = "Anda telah absen masuk. Jangan lupa absen pulang nanti.";
                showToast("Berhasil Absen Masuk pada " + timeStr, "success");

                const newRecord = {
                    id: Date.now(),
                    name: 'Karyawan Demo',
                    role: 'Staff Umum',
                    date: now.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }),
                    day: now.toLocaleDateString('id-ID', { weekday: 'long' }),
                    timeIn: timeStr,
                    timeOut: '--:--',
                    status: 'Hadir (Belum Pulang)',
                    late: isLate,
                    photoIn: photoUrl,
                    photoOut: null
                };
                
                appState.history.unshift(newRecord);
                dbInsert('history', newRecord); // Simpan ke Supabase Cloud
                renderHistory();

            } else if (jenis === 'pulang') {
                appState.hasClockedOut = true;
                appState.timeOut = timeStr;
                document.getElementById('status-time-out').innerText = timeStr;
                btnPulang.classList.add('hidden');
                statusSelesai.classList.remove('hidden');
                statusSelesai.classList.add('flex');
                msg.innerText = "Terima kasih. Anda telah menyelesaikan jam kerja hari ini.";
                showToast("Berhasil Absen Pulang pada " + timeStr, "success");

                if(appState.history.length > 0) {
                    appState.history[0].timeOut = timeStr;
                    appState.history[0].status = appState.history[0].late ? 'Terlambat' : 'Hadir';
                    appState.history[0].photoOut = photoUrl;
                    
                    // Update ke Supabase Cloud
                    dbUpdate('history', appState.history[0].id, {
                        timeOut: timeStr,
                        status: appState.history[0].status,
                        photoOut: photoUrl
                    });
                    
                    renderHistory();
                }
            }
        }

        function renderHistory() {
            const listContainer = document.getElementById('history-list');
            listContainer.innerHTML = ''; 

            let filteredData = appState.history;
            if (currentHistoryFilter === 'hadir') {
                filteredData = appState.history.filter(item => item.late === false);
            } else if (currentHistoryFilter === 'terlambat') {
                filteredData = appState.history.filter(item => item.late === true);
            }

            if (filteredData.length === 0) {
                listContainer.innerHTML = '<p class="text-center text-gray-400 text-sm mt-10">Belum ada riwayat absensi untuk kategori ini.</p>';
                return;
            }

            filteredData.forEach(item => {
                let statusColor = 'text-green-600 bg-green-50';
                if (item.late) statusColor = 'text-red-600 bg-red-50';
                if (item.status.includes('Belum')) statusColor = 'text-yellow-600 bg-yellow-50';

                let photoHtml = '';
                if(item.photoIn || item.photoOut) {
                    photoHtml = `<div class="flex mt-2">`;
                    if(item.photoIn) photoHtml += `<img src="${item.photoIn}" class="w-7 h-7 rounded-full border border-gray-200 object-cover shadow-sm" title="Selfie Masuk">`;
                    if(item.photoOut) photoHtml += `<img src="${item.photoOut}" class="w-7 h-7 rounded-full border border-gray-200 object-cover shadow-sm -ml-2" title="Selfie Pulang">`;
                    photoHtml += `</div>`;
                }

                const html = `
                    <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex justify-between items-center">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 rounded-lg bg-blue-50 text-blue-600 flex flex-col justify-center items-center">
                                <span class="text-xs font-bold">${item.date.split(' ')[0]}</span>
                                <span class="text-[10px] uppercase">${item.date.split(' ')[1]}</span>
                            </div>
                            <div>
                                <p class="font-bold text-gray-800 text-sm">${item.day}</p>
                                <div class="flex items-center space-x-2 text-xs text-gray-500 mt-1">
                                    <span><i class="fas fa-sign-in-alt text-green-500"></i> ${item.timeIn}</span>
                                    <span>-</span>
                                    <span><i class="fas fa-sign-out-alt text-red-500"></i> ${item.timeOut}</span>
                                </div>
                                ${photoHtml}
                            </div>
                        </div>
                        <div class="px-2 py-1 rounded text-[10px] font-bold ${statusColor}">
                            ${item.status}
                        </div>
                    </div>
                `;
                listContainer.insertAdjacentHTML('beforeend', html);
            });
        }

