        // --- FUNGSI MANAJEMEN SLIP GAJI ---
        function formatMonthYear(yyyymm) {
            if(!yyyymm) return '-';
            const [year, month] = yyyymm.split('-');
            const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
            return `${months[parseInt(month)-1]} ${year}`;
        }

        function submitPayslip() {
            const emp = document.getElementById('input-slip-emp').value;
            const periodVal = document.getElementById('input-slip-period').value;
            const fileInput = document.getElementById('input-slip-file');

            if (!periodVal || !fileInput.files[0]) {
                showToast('Periode bulan dan file PDF wajib diisi!', 'error');
                return;
            }

            const now = new Date();
            const dateStr = now.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
            
            const newSlip = {
                id: Date.now(),
                empName: emp,
                period: periodVal,
                periodLabel: formatMonthYear(periodVal),
                date: dateStr
            };

            appState.payslips.unshift(newSlip);
            dbInsert('payslips', newSlip); // Insert ke Supabase
            
            // Reset form
            document.getElementById('input-slip-period').value = '';
            fileInput.value = '';
            document.getElementById('slip-file-name').innerText = 'Klik untuk upload PDF';

            showToast('Slip Gaji berhasil diupload & dikirim!', 'success');
            
            renderAdminPayslips();
            renderEmployeePayslips();
        }

        function deletePayslip(id) {
            appState.payslips = appState.payslips.filter(p => p.id !== id);
            dbDelete('payslips', id); // Delete dari Supabase
            showToast('Slip gaji berhasil dihapus', 'success');
            renderAdminPayslips();
            renderEmployeePayslips();
        }

        function renderAdminPayslips() {
            const tbody = document.getElementById('admin-table-slip');
            if(!tbody) return;
            tbody.innerHTML = '';

            if (appState.payslips.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center py-8 text-gray-400">Belum ada slip gaji yang diunggah.</td></tr>`;
                return;
            }

            appState.payslips.forEach(slip => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-gray-50 transition-colors";
                tr.innerHTML = `
                    <td class="py-4 px-6 font-bold text-sm text-gray-800">${slip.periodLabel}</td>
                    <td class="py-4 px-6 text-sm text-gray-600">${slip.empName}</td>
                    <td class="py-4 px-6 text-xs text-gray-500">${slip.date}</td>
                    <td class="py-4 px-6">
                        <button onclick="if(confirm('Yakin ingin menghapus slip gaji ini?')) deletePayslip(${slip.id})" class="text-red-500 hover:text-red-700 bg-red-50 p-1.5 rounded-lg transition-transform active:scale-90" title="Hapus"><i class="fas fa-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function renderEmployeePayslips() {
            const container = document.getElementById('employee-payslip-list');
            if(!container) return;
            container.innerHTML = '';

            // Filter agar hanya memunculkan slip untuk "Karyawan Demo" (atau yg ditujukan untuk Semua Karyawan)
            const userSlips = appState.payslips.filter(s => s.empName === 'Karyawan Demo' || s.empName === 'Semua Karyawan');

            if(userSlips.length === 0) {
                container.innerHTML = `
                <div class="flex flex-col items-center justify-center py-10 text-gray-400">
                    <i class="fas fa-folder-open text-4xl mb-3 text-gray-300"></i>
                    <p class="text-sm font-medium">Belum ada slip gaji untuk Anda.</p>
                </div>`;
                return;
            }

            userSlips.forEach(slip => {
                const html = `
                <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex justify-between items-center transition-all hover:shadow-md">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-green-50 text-green-600 rounded-lg flex items-center justify-center text-lg">
                            <i class="fas fa-file-invoice-dollar"></i>
                        </div>
                        <div>
                            <p class="font-bold text-gray-800 text-sm">${slip.periodLabel}</p>
                            <p class="text-[10px] text-gray-500 mt-0.5">Diterbitkan: ${slip.date}</p>
                        </div>
                    </div>
                    <button onclick="simulateDownload(this, 'Slip_Gaji_${slip.periodLabel.replace(' ','_')}')" class="text-blue-600 hover:bg-blue-50 p-2 rounded-lg transition focus:outline-none" title="Download Slip">
                        <i class="fas fa-download"></i>
                    </button>
                </div>`;
                container.insertAdjacentHTML('beforeend', html);
            });
        }

        // --- FUNGSI PETA KARYAWAN (KEHADIRAN) ---
        let employeeMap = null;
        let employeeMarker = null;
        let employeeOfficeCircle = null;
        let watchId = null;

        // Hardcoded office location untuk demo (bisa ditarik dari data appState.locations nanti)
        const officeLat = -6.2088;
        const officeLng = 106.8456;
        const officeRadius = 50; // Radius toleransi absen 50 meter

        function initEmployeeMap() {
            if (!document.getElementById('employee-map')) return;

            if (!employeeMap) {
                // Inisialisasi peta tanpa tombol zoom agar tampilan mobile lebih bersih
                employeeMap = L.map('employee-map', { zoomControl: false }).setView([officeLat, officeLng], 16);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(employeeMap);
                
                // Gambar Area Geofence (Lingkaran Biru)
                employeeOfficeCircle = L.circle([officeLat, officeLng], {
                    color: '#3b82f6',
                    fillColor: '#3b82f6',
                    fillOpacity: 0.15,
                    weight: 2,
                    radius: officeRadius
                }).addTo(employeeMap);

                // Tandai Titik Tengah Kantor
                L.marker([officeLat, officeLng], {
                    icon: L.divIcon({
                        className: 'custom-div-icon',
                        html: "<div style='background-color:#3b82f6; width:12px; height:12px; border-radius:50%; border:2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.5); margin-top:-6px; margin-left:-6px;'></div>",
                        iconSize: [12, 12],
                        iconAnchor: [0, 0]
                    })
                }).addTo(employeeMap);

                startLocationTracking();
            } else {
                employeeMap.invalidateSize();
            }
        }

        function startLocationTracking() {
            if (navigator.geolocation) {
                watchId = navigator.geolocation.watchPosition(
                    (position) => {
                        const lat = position.coords.latitude;
                        const lng = position.coords.longitude;
                        const accuracy = position.coords.accuracy;
                        updateEmployeeLocation(lat, lng, accuracy);
                    },
                    (error) => {
                        console.warn("Geolocation error atau diblokir:", error);
                        // Fallback simulasi jika GPS diblokir browser (untuk keperluan demo agar peta tetap jalan)
                        simulateEmployeeLocation();
                    },
                    { enableHighAccuracy: true, timeout: 5000, maximumAge: 0 }
                );
            } else {
                simulateEmployeeLocation();
            }
        }

        function simulateEmployeeLocation() {
            // Simulasi titik lokasi user sedikit bergeser dari kantor pusat agar seolah-olah valid
            updateEmployeeLocation(officeLat + 0.0001, officeLng + 0.0001, 12.5);
        }

        function updateEmployeeLocation(lat, lng, accuracy) {
            if (!employeeMap) return;

            const latLng = [lat, lng];

            // Render/Update Marker User (Animasi Pulse Biru)
            if (!employeeMarker) {
                employeeMarker = L.marker(latLng, {
                    icon: L.divIcon({
                        className: 'user-marker',
                        html: "<div class='flex items-center justify-center w-10 h-10 bg-blue-500/20 rounded-full animate-pulse'><div class='w-4 h-4 bg-blue-600 border-2 border-white rounded-full shadow-[0_0_10px_rgba(37,99,235,0.8)]'></div></div>",
                        iconSize: [40, 40],
                        iconAnchor: [20, 20]
                    })
                }).addTo(employeeMap);
            } else {
                employeeMarker.setLatLng(latLng);
            }

            // Fokus peta ke lokasi user
            employeeMap.setView(latLng, 17);

            // Update Text Akurasi
            document.getElementById('gps-accuracy').innerText = `± ${accuracy.toFixed(1)} Meter`;
            
            // Kalkulasi jarak (Geofencing Logic)
            const distance = employeeMap.distance([officeLat, officeLng], latLng);
            const statusEl = document.getElementById('geofence-status');
            const locationTextEl = document.getElementById('employee-location-text');
            
            if (distance <= officeRadius) {
                statusEl.className = "px-3 py-1 bg-green-50 text-green-600 text-[10px] font-bold rounded-full border border-green-100 flex items-center shadow-sm";
                statusEl.innerHTML = "<i class='fas fa-check-circle mr-1'></i> Di Dalam Area";
                locationTextEl.innerText = "Kantor Pusat, Jakarta";
            } else {
                statusEl.className = "px-3 py-1 bg-red-50 text-red-600 text-[10px] font-bold rounded-full border border-red-100 flex items-center shadow-sm";
                statusEl.innerHTML = "<i class='fas fa-times-circle mr-1'></i> Di Luar Area";
                locationTextEl.innerText = "Berada di luar radius absen";
            }
        }

    </script>
