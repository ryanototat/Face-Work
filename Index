        async function loadAllData() {
            if(!supabaseClient) return;
            try {
                // Fetch Employees
                const { data: emp } = await supabaseClient.from('employees').select('*');
                if(emp && emp.length > 0) appState.employees = emp;
                
                // Fetch History
                const { data: hist } = await supabaseClient.from('history').select('*').order('id', {ascending: false});
                if(hist && hist.length > 0) appState.history = hist;

                // Fetch Locations
                const { data: loc } = await supabaseClient.from('locations').select('*');
                if(loc && loc.length > 0) appState.locations = loc;

                // Fetch Announcements
                const { data: ann } = await supabaseClient.from('announcements').select('*').order('id', {ascending: false});
                if(ann && ann.length > 0) appState.announcements = ann;

                // Fetch Payslips
                const { data: pay } = await supabaseClient.from('payslips').select('*').order('id', {ascending: false});
                if(pay && pay.length > 0) appState.payslips = pay;

                // Fetch Requests (Cuti, Lembur, etc)
                const { data: reqs } = await supabaseClient.from('requests').select('*').order('id', {ascending: false});
                if(reqs && reqs.length > 0) {
                    appState.requests = { cuti: [], lembur: [], manual: [], kasbon: [], reimburse: [] };
                    reqs.forEach(r => {
                        if(appState.requests[r.type]) appState.requests[r.type].push(r);
