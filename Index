        let pickerMap = null;
        let pickerMarker = null;
        let pickerCircle = null;

        function initOverviewMap() {
            if (!document.getElementById('map-overview')) return;
            
            if (!overviewMap) {
                overviewMap = L.map('map-overview').setView([-6.2088, 106.8456], 10);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OpenStreetMap'
                }).addTo(overviewMap);
                overviewLayerGroup = L.layerGroup().addTo(overviewMap);
            }
            
            updateOverviewMap();
            setTimeout(() => overviewMap.invalidateSize(), 300);
        }

        function updateOverviewMap() {
            if (!overviewMap || !overviewLayerGroup) return;
            overviewLayerGroup.clearLayers();
            
            const bounds = [];
            
            appState.locations.forEach(loc => {
                if (loc.lat && loc.lng) {
                    const latLng = [parseFloat(loc.lat), parseFloat(loc.lng)];
                    const radius = parseFloat(loc.radius || 0);
                    const color = loc.status === 'Aktif' ? '#3b82f6' : '#9ca3af';
                    
                    const marker = L.marker(latLng).bindPopup(`<b>${loc.name}</b><br>Radius: ${radius}m<br>Status: ${loc.status}`);
                    overviewLayerGroup.addLayer(marker);
                    
                    if (radius > 0) {
                        const circle = L.circle(latLng, {
                            color: color,
                            fillColor: color,
                            fillOpacity: 0.2,
                            radius: radius
                        });
                        overviewLayerGroup.addLayer(circle);
                    }
                    
                    bounds.push(latLng);
                }
            });
            
            if (bounds.length > 0) {
                overviewMap.fitBounds(bounds, { padding: [30, 30] });
            }
        }

        function initPickerMap() {
            if (!document.getElementById('map-picker')) return;

            const latInput = document.getElementById('input-loc-lat');
            const lngInput = document.getElementById('input-loc-lng');
            const radiusInput = document.getElementById('input-loc-radius');

            const lat = parseFloat(latInput.value) || -6.2088;
            const lng = parseFloat(lngInput.value) || 106.8456;
            const radius = parseFloat(radiusInput.value) || 50;

            if (!pickerMap) {
                pickerMap = L.map('map-picker').setView([lat, lng], 13);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(pickerMap);
                
                pickerMap.on('click', function(e) {
                    const newLat = e.latlng.lat.toFixed(6);
                    const newLng = e.latlng.lng.toFixed(6);
                    latInput.value = newLat;
                    lngInput.value = newLng;
                    updatePickerMarker(newLat, newLng, radiusInput.value);
                });

                // Update map when manual input changes
                latInput.addEventListener('input', () => updatePickerMarker(latInput.value, lngInput.value, radiusInput.value));
                lngInput.addEventListener('input', () => updatePickerMarker(latInput.value, lngInput.value, radiusInput.value));
                radiusInput.addEventListener('input', () => updatePickerMarker(latInput.value, lngInput.value, radiusInput.value));
            }
            
            setTimeout(() => {
                pickerMap.invalidateSize();
                pickerMap.setView([lat, lng], 15);
                updatePickerMarker(lat, lng, radius);
            }, 300);
        }

        function updatePickerMarker(lat, lng, radius) {
            if (!pickerMap) return;
            const parsedLat = parseFloat(lat);
            const parsedLng = parseFloat(lng);
            const r = parseFloat(radius || 0);
            
            if (isNaN(parsedLat) || isNaN(parsedLng)) return;

            const latLng = [parsedLat, parsedLng];
            
            if (pickerMarker) pickerMap.removeLayer(pickerMarker);
            if (pickerCircle) pickerMap.removeLayer(pickerCircle);
            
            pickerMarker = L.marker(latLng).addTo(pickerMap);
            if (r > 0) {
                pickerCircle = L.circle(latLng, {
                    color: '#3b82f6',
                    fillColor: '#3b82f6',
                    fillOpacity: 0.2,
                    radius: r
                }).addTo(pickerMap);
            }
            pickerMap.setView(latLng);
        }

