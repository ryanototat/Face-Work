<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Face Works</title>
    <!-- Tailwind CSS untuk Styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Peta Interaktif (Leaflet.js) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <!-- Supabase SDK -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <!-- FontAwesome untuk Ikon -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6;
        }
        /* Z-index fix for Leaflet agar tidak tumpang tindih dengan modal */
        .leaflet-container {
            z-index: 1 !important;
        }
        /* Animasi untuk Toast Notification */
        @keyframes slideInUp {
            from { transform: translateY(100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        @keyframes fadeOut {
            from { opacity: 1; }
            to { opacity: 0; }
        }
        .toast-enter {
            animation: slideInUp 0.3s ease-out forwards;
        }
        .toast-exit {
            animation: fadeOut 0.3s ease-out forwards;
        }
        /* Animasi pulse untuk tombol absen */
        .pulse-btn {
            box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7);
            animation: pulse-blue 2s infinite;
        }
        @keyframes pulse-blue {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 15px rgba(59, 130, 246, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
        }
        /* Hide scrollbar for clean mobile look */
        ::-webkit-scrollbar {
            width: 0px;
            background: transparent;
        }
    </style>
</head>
<body class="text-gray-800 antialiased bg-gray-100 font-sans h-screen w-full">

    <!-- VIEW: PINTU MASUK / PILIHAN AKSES (TANPA LOGIN) -->
    <div id="view-login" class="flex flex-col items-center justify-center min-h-screen p-6 animate-fade-in relative overflow-hidden">
        <!-- Background Decoration -->
        <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-indigo-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
        
        <div class="bg-white p-8 rounded-3xl shadow-2xl w-full max-w-sm z-10 text-center border border-gray-100">
            <div class="w-20 h-20 bg-gradient-to-tr from-blue-600 to-indigo-600 rounded-2xl flex items-center justify-center mx-auto shadow-lg mb-6">
                <i class="fas fa-fingerprint text-white text-4xl"></i>
            </div>
            <h1 class="text-2xl font-bold text-gray-800 mb-2">Face Works</h1>
            <p class="text-gray-500 text-sm mb-8">Pilih akses masuk Anda ke dalam sistem.</p>
            
            <!-- Tombol Pilihan Langsung Masuk -->
            <div id="role-selection" class="space-y-4 block">
                <button onclick="showView('employee')" class="w-full py-3.5 bg-blue-600 text-white rounded-xl font-semibold shadow-lg shadow-blue-500/30 hover:bg-blue-700 transition flex items-center justify-center space-x-3 focus:outline-none">
                    <i class="fas fa-user-tie text-lg"></i>
                    <span>Masuk sebagai Karyawan</span>
                </button>
                <button onclick="showAdminLoginForm()" class="w-full py-3.5 bg-gray-800 text-white rounded-xl font-semibold shadow-lg shadow-gray-800/30 hover:bg-gray-900 transition flex items-center justify-center space-x-3 focus:outline-none">
                    <i class="fas fa-desktop text-lg"></i>
                    <span>Masuk sebagai Admin HR</span>
                </button>
            </div>

            <!-- Form Login Admin (Hidden by default) -->
            <div id="admin-login-form" class="hidden space-y-4">
                <p class="text-sm text-gray-600 mb-2 font-medium">Otorisasi Admin HR</p>
                <div class="relative">
                    <i class="fas fa-lock absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                    <input type="password" id="admin-password" placeholder="Masukkan kata sandi..." class="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all" onkeypress="if(event.key === 'Enter') verifyAdminLogin()">
                </div>
                <button onclick="verifyAdminLogin()" class="w-full py-3.5 bg-gray-800 text-white rounded-xl font-semibold shadow-lg shadow-gray-800/30 hover:bg-gray-900 transition flex items-center justify-center space-x-2">
                    <i class="fas fa-sign-in-alt"></i>
                    <span>Masuk Dashboard</span>
                </button>
                <button onclick="hideAdminLoginForm()" class="w-full py-2 text-gray-500 hover:text-gray-700 text-sm font-medium transition focus:outline-none">
                    Kembali
                </button>
            </div>
        </div>
    </div>

    <!-- Container Utama (Desain Mobile-First) - KARYAWAN -->
    <div id="view-employee" class="hidden w-full max-w-md bg-slate-50 min-h-screen shadow-[0_0_40px_rgba(0,0,0,0.05)] relative mx-auto flex-col overflow-hidden">
        
        <!-- Header Profil -->
        <header class="bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-700 text-white p-6 rounded-b-[2.5rem] shadow-lg z-10 relative overflow-hidden">
            <!-- Decorative circles -->
            <div class="absolute top-[-20%] right-[-10%] w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
            <div class="absolute bottom-[-10%] left-[-10%] w-24 h-24 bg-white/10 rounded-full blur-xl"></div>
            
            <div class="flex justify-between items-center mb-5 relative z-10">
                <div>
                    <h1 class="text-xl font-bold"><span id="greeting-text">Halo</span>, Karyawan Demo</h1>
                    <p class="text-sm text-blue-200">Staff Umum</p>
                </div>
                <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold text-xl shadow-inner overflow-hidden relative">
                    <span id="header-profile-initials">KD</span>
                    <img id="header-profile-img" src="" class="hidden w-full h-full object-cover absolute inset-0 z-10">
                </div>
            </div>
            
            <!-- Info Tanggal Hari Ini -->
            <div class="bg-white/20 rounded-2xl p-3.5 flex items-center justify-between backdrop-blur-sm mt-4 relative z-10 border border-white/20 shadow-sm">
                <div class="flex items-center space-x-2.5">
                    <i class="fas fa-calendar-alt text-blue-100"></i>
                    <span id="current-date" class="text-sm font-medium">Memuat tanggal...</span>
                </div>
                <div class="text-xs bg-white/90 text-indigo-700 px-3 py-1.5 rounded-full font-bold shadow-sm">
                    Reguler
                </div>
            </div>
        </header>

        <!-- Konten Utama (Berubah sesuai Tab) -->
        <main class="flex-1 overflow-y-auto pb-24 px-5 pt-6 relative" id="main-content">
            
            <!-- SECTION 1: BERANDA -->
            <div id="section-home" class="block animate-fade-in">
                
                <!-- Banner Pengumuman -->
                <div id="employee-announcement-container">
                    <!-- Data pengumuman akan dimuat lewat JavaScript dari Admin -->
                </div>

                <!-- Menu Layanan Karyawan -->
                <div class="mb-2">
                    <h3 class="text-sm font-bold text-gray-800 mb-5 pl-1">Layanan Karyawan</h3>
                    <div class="grid grid-cols-4 gap-y-6 gap-x-2">
                        <!-- Cuti -->
                        <button onclick="openFeature('cuti')" class="flex flex-col items-center justify-start gap-2.5 focus:outline-none group">
                            <div class="w-14 h-14 bg-white text-indigo-500 rounded-2xl flex items-center justify-center text-2xl shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_8px_15px_rgba(99,102,241,0.15)] group-active:scale-95">
                                <i class="fas fa-calendar-minus"></i>
                            </div>
                            <span class="text-[11px] font-medium text-gray-600 text-center leading-tight group-hover:text-indigo-600 transition-colors">Cuti</span>
                        </button>
                        
                        <!-- Lembur -->
                        <button onclick="openFeature('lembur')" class="flex flex-col items-center justify-start gap-2.5 focus:outline-none group">
                            <div class="w-14 h-14 bg-white text-orange-500 rounded-2xl flex items-center justify-center text-2xl shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_8px_15px_rgba(249,115,22,0.15)] group-active:scale-95">
                                <i class="fas fa-business-time"></i>
                            </div>
                            <span class="text-[11px] font-medium text-gray-600 text-center leading-tight group-hover:text-orange-500 transition-colors">Lembur</span>
                        </button>

                        <!-- Kehadiran Manual -->
                        <button onclick="openFeature('manual')" class="flex flex-col items-center justify-start gap-2.5 focus:outline-none group">
                            <div class="w-14 h-14 bg-white text-teal-500 rounded-2xl flex items-center justify-center text-2xl shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_8px_15px_rgba(20,184,166,0.15)] group-active:scale-95">
                                <i class="fas fa-clipboard-check"></i>
                            </div>
                            <span class="text-[11px] font-medium text-gray-600 text-center leading-tight group-hover:text-teal-500 transition-colors">Kehadiran<br>Manual</span>
                        </button>

                        <!-- Kasbon -->
                        <button onclick="openFeature('kasbon')" class="flex flex-col items-center justify-start gap-2.5 focus:outline-none group">
                            <div class="w-14 h-14 bg-white text-green-500 rounded-2xl flex items-center justify-center text-2xl shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_8px_15px_rgba(34,197,94,0.15)] group-active:scale-95">
                                <i class="fas fa-hand-holding-usd"></i>
                            </div>
                            <span class="text-[11px] font-medium text-gray-600 text-center leading-tight group-hover:text-green-500 transition-colors">Kasbon</span>
                        </button>

                        <!-- Reimburse -->
                        <button onclick="openFeature('reimburse')" class="flex flex-col items-center justify-start gap-2.5 focus:outline-none group">
                            <div class="w-14 h-14 bg-white text-blue-500 rounded-2xl flex items-center justify-center text-2xl shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_8px_15px_rgba(59,130,246,0.15)] group-active:scale-95">
                                <i class="fas fa-file-invoice-dollar"></i>
                            </div>
                            <span class="text-[11px] font-medium text-gray-600 text-center leading-tight group-hover:text-blue-500 transition-colors">Reimburse</span>
                        </button>

                        <!-- Kalender -->
                        <button onclick="openFeature('kalender')" class="flex flex-col items-center justify-start gap-2.5 focus:outline-none group">
                            <div class="w-14 h-14 bg-white text-rose-500 rounded-2xl flex items-center justify-center text-2xl shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100 transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_8px_15px_rgba(244,63,94,0.15)] group-active:scale-95">
                                <i class="fas fa-calendar-day"></i>
                            </div>
                            <span class="text-[11px] font-medium text-gray-600 text-center leading-tight group-hover:text-rose-500 transition-colors">Kalender</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- SECTION 2: KEHADIRAN (BARU) -->
            <div id="section-kehadiran" class="hidden animate-fade-in">
                <!-- Jam Digital -->
                <div class="text-center mb-6 bg-white p-5 rounded-3xl shadow-[0_8px_30px_rgba(0,0,0,0.04)] border border-gray-50">
                    <h2 class="text-gray-400 text-xs font-semibold uppercase tracking-widest mb-1">Waktu Saat Ini</h2>
                    <div id="digital-clock" class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600 tracking-tight mb-2">00:00:00</div>
                    <div class="flex items-center justify-center space-x-2 text-xs font-medium text-gray-500 bg-gray-50 py-1.5 px-3 rounded-full inline-flex">
                        <i class="fas fa-map-marker-alt text-red-500"></i>
                        <span id="employee-location-text">Mencari lokasi GPS...</span>
                    </div>
                </div>

                <!-- Peta Lokasi (Live Tracking) -->
                <div class="mb-6 rounded-3xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.04)] border border-gray-50 relative h-48 bg-gray-100">
                    <div id="employee-map" class="w-full h-full z-0"></div>
                    <!-- Overlay Info -->
                    <div class="absolute bottom-3 left-3 right-3 bg-white/90 backdrop-blur-sm p-3 rounded-2xl shadow-sm z-10 flex items-center justify-between border border-white/50">
                        <div class="flex items-center space-x-3">
                            <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center text-blue-500">
                                <i class="fas fa-location-arrow"></i>
                            </div>
                            <div>
                                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Akurasi GPS</p>
                                <p id="gps-accuracy" class="text-xs font-bold text-gray-800">Menghitung...</p>
                            </div>
                        </div>
                        <div id="geofence-status" class="px-3 py-1 bg-yellow-50 text-yellow-600 text-[10px] font-bold rounded-full border border-yellow-100 flex items-center">
                            <i class="fas fa-spinner fa-spin mr-1"></i> Memeriksa Area
                        </div>
                    </div>
                </div>

                <!-- Status Card -->
                <div class="bg-white rounded-3xl p-1 shadow-[0_8px_30px_rgba(0,0,0,0.04)] border border-gray-50 mb-10">
                    <div class="flex justify-between items-center bg-gray-50/50 rounded-2xl p-4">
                        <div class="text-center flex-1 border-r border-gray-200/60">
                            <p class="text-[10px] text-gray-400 font-semibold uppercase tracking-wider mb-1">Jam Masuk</p>
                            <p id="status-time-in" class="text-xl font-bold text-gray-800">--:--</p>
                        </div>
                        <div class="text-center flex-1">
                            <p class="text-[10px] text-gray-400 font-semibold uppercase tracking-wider mb-1">Jam Pulang</p>
                            <p id="status-time-out" class="text-xl font-bold text-gray-800">--:--</p>
                        </div>
                    </div>
                </div>

                <!-- Tombol Absen -->
                <div class="flex justify-center items-center mb-6 relative">
                    <!-- Tombol Masuk -->
                    <button id="btn-masuk" onclick="openCamera('masuk')" class="w-40 h-40 bg-gradient-to-tr from-blue-500 to-blue-600 rounded-full text-white shadow-xl flex flex-col items-center justify-center pulse-btn transition-transform active:scale-95">
                        <i class="fas fa-camera text-4xl mb-2"></i>
                        <span class="font-bold text-lg">Absen Masuk</span>
                    </button>

                    <!-- Tombol Pulang (Awalnya Sembunyi) -->
                    <button id="btn-pulang" onclick="openCamera('pulang')" class="hidden w-40 h-40 bg-gradient-to-tr from-orange-400 to-red-500 rounded-full text-white shadow-xl flex flex-col items-center justify-center transition-transform active:scale-95">
                        <i class="fas fa-camera text-4xl mb-2"></i>
                        <span class="font-bold text-lg">Absen Pulang</span>
                    </button>

                    <!-- Status Selesai (Awalnya Sembunyi) -->
                    <div id="status-selesai" class="hidden w-40 h-40 bg-gray-100 border-4 border-green-500 rounded-full text-green-600 shadow-inner flex flex-col items-center justify-center">
                        <i class="fas fa-check-circle text-4xl mb-2"></i>
                        <span class="font-bold text-sm text-center">Tugas Hari Ini<br>Selesai</span>
                    </div>
                </div>

                <p id="absen-message" class="text-center text-sm text-gray-500">Silakan tekan tombol di atas untuk absen.</p>
            </div>

            <!-- SECTION 3: RIWAYAT -->
            <div id="section-history" class="hidden">
                <h2 class="text-lg font-bold text-gray-800 mb-4">Riwayat Absensi (Bulan Ini)</h2>
                
                <!-- Filter Singkat -->
                <div class="flex space-x-2 mb-4 overflow-x-auto pb-1" id="history-filters">
                    <button onclick="filterHistory('semua')" id="filter-semua" class="bg-blue-600 text-white border border-blue-600 px-4 py-1.5 rounded-full text-xs font-medium whitespace-nowrap shadow-sm transition-colors">Semua</button>
                    <button onclick="filterHistory('hadir')" id="filter-hadir" class="bg-white border border-gray-200 text-gray-600 px-4 py-1.5 rounded-full text-xs font-medium whitespace-nowrap hover:bg-gray-50 transition-colors">Hadir</button>
                    <button onclick="filterHistory('terlambat')" id="filter-terlambat" class="bg-white border border-gray-200 text-gray-600 px-4 py-1.5 rounded-full text-xs font-medium whitespace-nowrap hover:bg-gray-50 transition-colors">Terlambat</button>
                </div>

                <!-- Daftar Riwayat -->
                <div id="history-list" class="space-y-3">
                    <!-- Item riwayat akan digenerate oleh JavaScript -->
                </div>
            </div>

            <!-- SECTION 4: PROFIL -->
            <div id="section-profile" class="hidden animate-fade-in">
                <h2 class="text-lg font-bold text-gray-800 mb-4">Profil Saya</h2>
                
                <!-- Kartu Info Utama -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 text-center mb-5">
                    <div class="w-24 h-24 bg-blue-100 mx-auto rounded-full flex items-center justify-center text-blue-600 font-bold text-4xl mb-3 relative cursor-pointer group" onclick="document.getElementById('profile-upload').click()" title="Klik untuk ubah foto">
                        <span id="profile-initials">KD</span>
                        <img id="profile-img" src="" class="hidden w-full h-full rounded-full object-cover shadow-sm border-2 border-white">
                        
                        <!-- Overlay kamera saat hover -->
                        <div class="absolute inset-0 bg-black/40 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <i class="fas fa-camera text-white text-xl"></i>
                        </div>
                        
                        <!-- Indikator Status Aktif -->
                        <div class="absolute bottom-1 right-1 w-5 h-5 bg-green-500 border-2 border-white rounded-full z-10"></div>
                    </div>
                    <!-- Input File Tersembunyi -->
                    <input type="file" id="profile-upload" accept="image/*" class="hidden" onchange="handleProfileUpload(event)">
                    <p class="text-[10px] text-gray-400 mb-2 mt(-2)">Maks. 10MB</p>

                    <h3 class="font-bold text-lg text-gray-800">Karyawan Demo</h3>
                    <p class="text-gray-500 text-sm mb-4">NIK: 2026000001</p>
                    
                    <div class="grid grid-cols-2 gap-3 text-left">
                        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
                            <p class="text-[11px] text-gray-500 mb-0.5">Departemen</p>
                            <p class="font-medium text-sm text-gray-800">Umum</p>
                        </div>
                        <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
                            <p class="text-[11px] text-gray-500 mb-0.5">Jabatan</p>
                            <p class="font-medium text-sm text-gray-800">Staff</p>
                        </div>
                    </div>
                </div>

                <!-- Daftar Menu Profil Tambahan -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
                    
                    <!-- Info Pribadi -->
                    <button onclick="openFeature('info-pribadi')" class="w-full flex items-center justify-between p-4 border-b border-gray-50 hover:bg-gray-50 transition-colors focus:outline-none">
                        <div class="flex items-center space-x-3">
                            <div class="w-9 h-9 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center">
                                <i class="fas fa-user"></i>
                            </div>
                            <span class="text-sm font-medium text-gray-700">Info Pribadi</span>
                        </div>
                        <i class="fas fa-chevron-right text-gray-300 text-xs"></i>
                    </button>
                    
                    <!-- Info Pekerjaan -->
                    <button onclick="openFeature('info-pekerjaan')" class="w-full flex items-center justify-between p-4 border-b border-gray-50 hover:bg-gray-50 transition-colors focus:outline-none">
                        <div class="flex items-center space-x-3">
                            <div class="w-9 h-9 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center">
                                <i class="fas fa-briefcase"></i>
                            </div>
                            <span class="text-sm font-medium text-gray-700">Info Pekerjaan</span>
                        </div>
                        <i class="fas fa-chevron-right text-gray-300 text-xs"></i>
                    </button>

                    <!-- Info Kontak Darurat -->
                    <button onclick="openFeature('kontak-darurat')" class="w-full flex items-center justify-between p-4 border-b border-gray-50 hover:bg-gray-50 transition-colors focus:outline-none">
                        <div class="flex items-center space-x-3">
                            <div class="w-9 h-9 rounded-full bg-red-50 text-red-500 flex items-center justify-center">
                                <i class="fas fa-heartbeat"></i>
                            </div>
                            <span class="text-sm font-medium text-gray-700">Info Kontak Darurat</span>
                        </div>
                        <i class="fas fa-chevron-right text-gray-300 text-xs"></i>
                    </button>

                    <!-- Slip Gaji -->
                    <button onclick="openFeature('slip-gaji')" class="w-full flex items-center justify-between p-4 border-b border-gray-50 hover:bg-gray-50 transition-colors focus:outline-none">
                        <div class="flex items-center space-x-3">
                            <div class="w-9 h-9 rounded-full bg-green-50 text-green-600 flex items-center justify-center">
                                <i class="fas fa-file-invoice-dollar"></i>
                            </div>
                            <span class="text-sm font-medium text-gray-700">Slip Gaji</span>
                        </div>
                        <i class="fas fa-chevron-right text-gray-300 text-xs"></i>
                    </button>

                    <!-- Pengaturan -->
                    <button onclick="openFeature('pengaturan')" class="w-full flex items-center justify-between p-4 hover:bg-gray-50 transition-colors focus:outline-none">
                        <div class="flex items-center space-x-3">
                            <div class="w-9 h-9 rounded-full bg-gray-100 text-gray-600 flex items-center justify-center">
                                <i class="fas fa-cog"></i>
                            </div>
                            <span class="text-sm font-medium text-gray-700">Pengaturan</span>
                        </div>
                        <i class="fas fa-chevron-right text-gray-300 text-xs"></i>
                    </button>

                </div>
                
                <!-- Tombol Keluar -->
                <button onclick="logout()" class="w-full py-3.5 text-red-500 bg-white border border-red-100 shadow-sm rounded-xl font-semibold hover:bg-red-50 transition flex items-center justify-center space-x-2 focus:outline-none mb-2">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Kembali ke Menu Utama</span>
                </button>
            </div>

