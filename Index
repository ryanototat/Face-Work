        function handleProfileUpload(event) {
            const file = event.target.files[0];
            if (!file) return;

            const maxSize = 10 * 1024 * 1024;
            if (file.size > maxSize) {
                showToast('Ukuran foto terlalu besar. Maksimal 10MB!', 'error');
                event.target.value = '';
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                // Update foto di halaman profil
                const imgElement = document.getElementById('profile-img');
                const initialsElement = document.getElementById('profile-initials');
                
                imgElement.src = e.target.result;
                imgElement.classList.remove('hidden');
                initialsElement.classList.add('hidden');
                
                // Update foto di header bar atas
                const headerImgElement = document.getElementById('header-profile-img');
                const headerInitialsElement = document.getElementById('header-profile-initials');
                
                if (headerImgElement && headerInitialsElement) {
                    headerImgElement.src = e.target.result;
                    headerImgElement.classList.remove('hidden');
                    headerInitialsElement.classList.add('hidden');
                }
                
                showToast('Foto profil berhasil diperbarui', 'success');
            };
            reader.readAsDataURL(file);
        }

